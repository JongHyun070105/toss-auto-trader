# Toss Open API credentials. 실제 값은 .env에만 넣고 git에 커밋하지 말 것.
TOSS_CLIENT_ID=c_xxxxxxxxxxxxxxxxxxxxx
TOSS_CLIENT_SECRET=s_xxxxxxxxxxxxxxxxxxxxx

# Optional. 비워두면 get-accounts로 조회 후 사용.
TOSS_ACCOUNT_SEQ=

# Safety defaults
TOSS_DRY_RUN=true
TOSS_LIVE_TRADING=false
# Optional. 0/empty = use full Toss cashBuyingPower; set e.g. 10000 to cap a live buy.
TOSS_MAX_BUY_AMOUNT_KRW=0

# Runtime
TOSS_DB_PATH=data/toss_lab.sqlite3
